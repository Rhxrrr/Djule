{
  "name": "Djule",
  "scopeName": "source.djule",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#imports-from"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#function-definition"
    },
    {
      "include": "#component-tags"
    },
    {
      "include": "#html-tags"
    },
    {
      "include": "#text-content"
    },
    {
      "include": "#interpolation"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#function-calls"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.djule",
          "match": "#.*$"
        }
      ]
    },
    "imports-from": {
      "patterns": [
        {
          "name": "meta.import.from.djule",
          "begin": "\\b(from)\\b\\s+",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.import.from.djule"
            }
          },
          "end": "(?=\\s+\\bimport\\b)",
          "patterns": [
            {
              "name": "entity.name.type.class.djule",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.namespace.djule",
              "match": "\\."
            }
          ]
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.djule",
          "begin": "\\b(import)\\b\\s+",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.import.djule"
            }
          },
          "end": "$",
          "patterns": [
            {
              "name": "entity.name.type.class.djule",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.namespace.djule",
              "match": "\\."
            },
            {
              "name": "punctuation.separator.comma.djule",
              "match": ","
            }
          ]
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "name": "meta.function.definition.djule",
          "begin": "\\b(def)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": {
              "name": "storage.type.function.djule"
            },
            "2": {
              "name": "entity.name.function.djule"
            },
            "3": {
              "name": "punctuation.section.parameters.begin.djule"
            }
          },
          "end": "(\\))\\s*(:)",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.parameters.end.djule"
            },
            "2": {
              "name": "punctuation.separator.colon.djule"
            }
          },
          "patterns": [
            {
              "name": "variable.parameter.djule",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.comma.djule",
              "match": ","
            }
          ]
        }
      ]
    },
    "component-tags": {
      "patterns": [
        {
          "name": "meta.tag.component.djule",
          "begin": "(</?)([A-Z][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.tag.begin.djule"
            },
            "2": {
              "name": "entity.name.type.class.djule"
            }
          },
          "end": "(>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.tag.end.djule"
            }
          },
          "patterns": [
            {
              "include": "#tag-attributes"
            }
          ]
        }
      ]
    },
    "html-tags": {
      "patterns": [
        {
          "name": "meta.tag.html.djule",
          "begin": "(</?)([a-z][a-z0-9-]*)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.tag.begin.djule"
            },
            "2": {
              "name": "entity.name.tag.djule"
            }
          },
          "end": "(>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.tag.end.djule"
            }
          },
          "patterns": [
            {
              "include": "#tag-attributes"
            }
          ]
        }
      ]
    },
    "tag-attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.djule",
          "match": "\\b[a-zA-Z_:][-a-zA-Z0-9_:.]*\\b(?=\\s*=)"
        },
        {
          "name": "keyword.operator.assignment.djule",
          "match": "="
        },
        {
          "include": "#interpolation"
        },
        {
          "include": "#strings"
        }
      ]
    },
    "text-content": {
      "patterns": [
        {
          "name": "text.plain.djule",
          "match": "^\\s+[A-Za-z][A-Za-z0-9 ,.'!?-]*$"
        },
        {
          "name": "text.plain.djule",
          "match": "(?<=>)\\s*[^<{\\n][^<{\\n]*(?=(\\{|<))"
        },
        {
          "name": "text.plain.djule",
          "match": "(?<=\\})\\s*[^<{\\n][^<{\\n]*(?=<)"
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.djule",
          "begin": "\\{",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.embedded.begin.djule"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.embedded.end.djule"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#component-tags"
            },
            {
              "include": "#html-tags"
            },
            {
              "include": "#text-content"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#keywords"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#function-calls"
            },
            {
              "include": "#variables"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.djule",
          "begin": "([fFrRuUbB]*)\"",
          "beginCaptures": {
            "1": {
              "name": "storage.type.string-prefix.djule"
            }
          },
          "end": "\"",
          "patterns": [
            {
              "include": "#interpolation"
            }
          ]
        },
        {
          "name": "string.quoted.single.djule",
          "begin": "([fFrRuUbB]*)'",
          "beginCaptures": {
            "1": {
              "name": "storage.type.string-prefix.djule"
            }
          },
          "end": "'",
          "patterns": [
            {
              "include": "#interpolation"
            }
          ]
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.djule",
          "match": "\\b(True|False|None)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.djule",
          "match": "\\b(if|else|for|in|return|from|import|not)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.djule",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "support.function.djule",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.readwrite.djule",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "punctuation.accessor.djule",
          "match": "\\."
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "punctuation.separator.operator.djule",
          "match": "\\+\\=|\\=\\=|\\!\\=|\\>\\=|\\<\\=|\\=|\\+|\\-|\\*|\\/"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.djule",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.djule",
          "match": ":"
        },
        {
          "name": "punctuation.section.group.begin.djule",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.djule",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.djule",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.djule",
          "match": "\\]"
        }
      ]
    }
  }
}
