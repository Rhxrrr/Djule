def Section(title, children):
    return (
        <section class="section">
            <h2>{title}</h2>
            <div class="section-body">
                {children}
            </div>
        </section>
    )

def Page():
    return (
        <Section title="Overview">
            <p>Nested content is passed through the reserved children prop.</p>
        </Section>
    )
